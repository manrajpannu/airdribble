{
    "swagger": "2.0",
    "info": {
        "description": "This is the API documentation for the RL-Dart application.",
        "title": "RL-Dart API",
        "contact": {},
        "version": "1.0"
    },
    "paths": {
        "/api/v1/challenge": {
            "get": {
                "description": "Retrieve a specific challenge using its ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "challenges"
                ],
                "summary": "Get a challenge by ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Challenge ID",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {}
            }
        },
        "/api/v1/challenges": {
            "get": {
                "description": "Retrieve a list of all challenges",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "challenges"
                ],
                "summary": "Get all challenges",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/database.Challenge"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/challenges/session/end": {
            "patch": {
                "description": "Marks a challenge session as completed",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "challenge_sessions"
                ],
                "summary": "End a challenge session",
                "parameters": [
                    {
                        "description": "Score information",
                        "name": "score",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/database.Score"
                        }
                    }
                ],
                "responses": {}
            }
        },
        "/api/v1/challenges/{challenge_id}/session": {
            "post": {
                "description": "Starts a new session for a challenge and returns the session token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "challenge_sessions"
                ],
                "summary": "Start a new challenge session",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "ID of the challenge to start a session for",
                        "name": "challenge_id",
                        "in": "path",
                        "required": true
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Session successfully created",
                        "schema": {
                            "$ref": "#/definitions/gin.H"
                        }
                    },
                    "400": {
                        "description": "Invalid challenge ID, Challenge ID does not exist, or Missing user_token cookie",
                        "schema": {
                            "$ref": "#/definitions/gin.H"
                        }
                    },
                    "500": {
                        "description": "Database error or Failed to generate token/create challenge session",
                        "schema": {
                            "$ref": "#/definitions/gin.H"
                        }
                    }
                }
            }
        },
        "/api/v1/leaderboard": {
            "get": {
                "description": "Retrieve the global leaderboard for a specific challenge",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "leaderboards"
                ],
                "summary": "Get challenge leaderboard",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Challenge ID",
                        "name": "challenge_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "array",
                                "items": {
                                    "type": "object",
                                    "additionalProperties": true
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/me/best-score": {
            "get": {
                "description": "Retrieve the best score for the authenticated user for a given challenge",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scores"
                ],
                "summary": "Get best score for current user",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Challenge ID",
                        "name": "challenge_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/database.Score"
                        }
                    }
                }
            }
        },
        "/api/v1/me/percentile": {
            "get": {
                "description": "Retrieve the percentile rank for the authenticated user for a given challenge",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scores"
                ],
                "summary": "Get percentile rank for current user",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Challenge ID",
                        "name": "challenge_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "number",
                                "format": "float64"
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/me/scores": {
            "get": {
                "description": "Retrieve all scores for the authenticated user for a given challenge",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "scores"
                ],
                "summary": "Get scores for current user",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Challenge ID",
                        "name": "challenge_id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/database.Score"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/rank": {
            "get": {
                "description": "Retrieve a specific rank using its ID",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ranks"
                ],
                "summary": "Get a rank by ID",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "Rank ID",
                        "name": "id",
                        "in": "query",
                        "required": true
                    }
                ],
                "responses": {}
            }
        },
        "/api/v1/ranks": {
            "get": {
                "description": "Retrieve a list of all ranks",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ranks"
                ],
                "summary": "Get all ranks",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "array",
                            "items": {
                                "type": "array",
                                "items": {
                                    "$ref": "#/definitions/database.Rank"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/api/v1/users/guest": {
            "post": {
                "description": "creates a guest user account in the database and returns a token",
                "consumes": [
                    "application/json"
                ],
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "users"
                ],
                "summary": "Create a guest user and returns a token",
                "parameters": [
                    {
                        "description": "Guest user info",
                        "name": "guest_user",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/database.GuestUser"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Created",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "database.Challenge": {
            "type": "object",
            "required": [
                "config_json",
                "difficulty",
                "duration_ms",
                "name",
                "seed_type"
            ],
            "properties": {
                "active": {
                    "type": "boolean"
                },
                "config_json": {
                    "type": "string"
                },
                "created_at": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "difficulty": {
                    "type": "integer"
                },
                "duration_ms": {
                    "type": "integer"
                },
                "id": {
                    "type": "integer"
                },
                "name": {
                    "type": "string"
                },
                "seed_type": {
                    "type": "string"
                },
                "updated_at": {
                    "type": "string"
                }
            }
        },
        "database.GuestUser": {
            "type": "object",
