        },
        "database.Score": {
            "type": "object",
            "required": [
                "score"
            ],
            "properties": {
                "challenge_id": {
                    "type": "integer"
                },
                "created_at": {
                    "type": "string"
                },
                "id": {
                    "type": "integer"
                },
                "score": {
